@model HDKmall.Models.Banner
@{
    ViewData["Title"] = "Sửa Banner";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a asp-area="Admin" asp-controller="Banner" asp-action="Index" class="text-muted text-decoration-none small">
            <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
        </a>
        <h2 class="fw-bold mb-0 mt-1">✏️ Sửa Banner #@Model.Id</h2>
    </div>
</div>

<div class="row g-4">
    <!-- Form -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                <h5 class="fw-bold mb-0 text-secondary">Thông tin banner</h5>
            </div>
            <div class="card-body px-4 pb-4">
                <form asp-area="Admin" asp-controller="Banner" asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label asp-for="ImageUrl" class="form-label fw-semibold text-dark">URL Ảnh</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-link-45deg text-muted"></i></span>
                            <input asp-for="ImageUrl" class="form-control border-start-0 bg-light" id="bannerUrl" placeholder="https://..." />
                        </div>
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold text-dark">Thay Ảnh Mới</label>
                        <div class="border-2 border-dashed rounded-3 p-3 text-center bg-light" style="border-style:dashed; cursor:pointer;" onclick="document.getElementById('bannerFile').click()">
                            <i class="bi bi-cloud-upload fs-3 text-muted d-block mb-1"></i>
                            <span class="text-muted small">Nhấn để chọn ảnh mới</span>
                        </div>
                        <input asp-for="ImageFile" type="file" class="form-control mt-2" accept="image/*" id="bannerFile" style="display:none;" />
                        <div id="fileNameDisplay" class="text-muted small mt-1"></div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-semibold text-dark">Tiêu Đề Banner</label>
                        <input asp-for="Title" class="form-control bg-light" id="bannerTitle" placeholder="VD: iPhone 16 Pro Max" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold text-dark">Mô Tả Bổ Sung</label>
                        <textarea asp-for="Description" class="form-control bg-light" id="bannerDescription" rows="2" placeholder="VD: Sức mạnh Titanium - Đột phá công nghệ..."></textarea>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="BadgeText" class="form-label fw-semibold text-dark">Nhãn (Badge)</label>
                            <input asp-for="BadgeText" class="form-control bg-light" id="bannerBadge" placeholder="VD: Sản phẩm hot" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ButtonText" class="form-label fw-semibold text-dark">Chữ trên nút bấm</label>
                            <input asp-for="ButtonText" class="form-control bg-light" id="bannerBtnText" placeholder="VD: Khám phá ngay" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="LinkUrl" class="form-label fw-semibold text-dark">Đường Dẫn Khi Click</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-cursor text-muted"></i></span>
                            <input asp-for="LinkUrl" class="form-control border-start-0 bg-light" id="bannerLink" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" style="width:2.5em; height:1.3em;" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold ms-2">Hiển thị banner</label>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-4 pt-2 border-top">
                        <button type="submit" class="btn btn-danger fw-bold px-4 rounded-pill shadow-sm">
                            <i class="bi bi-check-circle me-1"></i>Cập Nhật Banner
                        </button>
                        <a asp-area="Admin" asp-controller="Banner" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Preview -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top:90px;">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                <h5 class="fw-bold mb-0 text-secondary">
                    <i class="bi bi-eye me-2"></i>Xem Trước
                </h5>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="rounded-3 overflow-hidden bg-light" style="height:200px; position:relative;">
                    <img id="bannerPreviewImage"
                         data-preview-src="@Model.ImageUrl"
                         src="@Model.ImageUrl" alt="Preview"
                         style="width:100%; height:100%; object-fit:cover; @(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")" />
                    <div id="noImagePlaceholder" class="d-flex flex-column align-items-center justify-content-center h-100 text-muted"
                         style="@(!string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")">
                        <i class="bi bi-image fs-1 mb-2"></i>
                        <span class="small">Chưa có ảnh</span>
                    </div>
                </div>
                <div class="mt-3 p-3 bg-light rounded-3" style="background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);">
                    <span class="badge bg-danger mb-2" id="bannerPreviewBadge">@(Model.BadgeText ?? "Nhãn")</span>
                    <div class="fw-bold text-white mb-1" id="bannerPreviewTitle" style="font-size:18px;">@(Model.Title ?? "(Tiêu đề banner)")</div>
                    <div class="text-white-50 small mb-2" id="bannerPreviewDesc" style="font-size: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        @(Model.Description ?? "(Mô tả banner)")
                    </div>
                    <a href="#" class="btn btn-sm btn-light text-danger fw-bold rounded-pill px-3 py-1" id="bannerPreviewBtn" onclick="return false;">@(Model.ButtonText ?? "Nút bấm")</a>
                    <div class="text-white-50 small mt-2 text-truncate" id="bannerPreviewLink" style="font-size: 11px;">
                        <i class="bi bi-link-45deg"></i> @(Model.LinkUrl ?? "(Đường dẫn)")
                    </div>
                </div>
                <div class="mt-2 text-center">
                    <span id="previewStatusBadge"
                          class="badge @(Model.IsActive ? "bg-success bg-opacity-10 text-success border-success-subtle" : "bg-secondary bg-opacity-10 text-secondary border-secondary-subtle") border px-3 py-2 rounded-pill">
                        <i class="bi @(Model.IsActive ? "bi-eye-fill" : "bi-eye-slash-fill") me-1"></i>
                        @(Model.IsActive ? "Đang hiển thị" : "Đang ẩn")
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateBannerPreview() {
            const url = document.getElementById('bannerUrl').value;
            const title = document.getElementById('bannerTitle').value;
            const desc = document.getElementById('bannerDescription').value;
            const badgeText = document.getElementById('bannerBadge').value;
            const btnText = document.getElementById('bannerBtnText').value;
            const link = document.getElementById('bannerLink').value;
            const isActive = document.getElementById('IsActive').checked;

            document.getElementById('bannerPreviewTitle').innerText = title || "(Tiêu đề banner)";
            document.getElementById('bannerPreviewDesc').innerText = desc || "(Mô tả banner)";
            document.getElementById('bannerPreviewBadge').innerText = badgeText || "Nhãn";
            document.getElementById('bannerPreviewBtn').innerText = btnText || "Nút bấm";
            document.getElementById('bannerPreviewLink').innerHTML = `<i class="bi bi-link-45deg"></i> ${link || "(Đường dẫn)"}`;

            const badge = document.getElementById('previewStatusBadge');
            if (isActive) {
                badge.className = 'badge bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-2 rounded-pill';
                badge.innerHTML = '<i class="bi bi-eye-fill me-1"></i>Đang hiển thị';
            } else {
                badge.className = 'badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle px-3 py-2 rounded-pill';
                badge.innerHTML = '<i class="bi bi-eye-slash-fill me-1"></i>Đang ẩn';
            }

            if (url) {
                const img = document.getElementById('bannerPreviewImage');
                img.src = url;
                img.style.display = 'block';
                document.getElementById('noImagePlaceholder').style.display = 'none';
            }
        }

        document.getElementById('bannerUrl').addEventListener('input', updateBannerPreview);
        document.getElementById('bannerTitle').addEventListener('input', updateBannerPreview);
        document.getElementById('bannerDescription').addEventListener('input', updateBannerPreview);
        document.getElementById('bannerBadge').addEventListener('input', updateBannerPreview);
        document.getElementById('bannerBtnText').addEventListener('input', updateBannerPreview);
        document.getElementById('bannerLink').addEventListener('input', updateBannerPreview);
        document.getElementById('IsActive').addEventListener('change', updateBannerPreview);

        document.getElementById('bannerFile').addEventListener('change', function () {
            const img = document.getElementById('bannerPreviewImage');
            const placeholder = document.getElementById('noImagePlaceholder');
            const fileDisplay = document.getElementById('fileNameDisplay');
            if (this.files && this.files[0]) {
                fileDisplay.textContent = '📎 ' + this.files[0].name;
                const reader = new FileReader();
                reader.onload = e => {
                    img.src = e.target.result;
                    img.style.display = 'block';
                    placeholder.style.display = 'none';
                };
                reader.readAsDataURL(this.files[0]);
            }
        });
    </script>
}