@model HDKmall.ViewModels.ProductVM

@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới ";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .version-card {
        border: 1px solid #e0e0e0;
        transition: all 0.3s ease;
    }
    .version-card:hover {
        border-color: #0d6efd;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1) !important;
    }
    .nested-card {
        background-color: #f8f9fa;
        border: 1px dashed #dee2e6;
    }
    .btn-remove {
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }
    
    .preview-current-price { color: #d70018; font-size: 2.2rem; font-weight: 800; line-height: 1; }
    .preview-option-item { border: 1.5px solid #e0e0e0; border-radius: 10px; padding: 10px; background: #fff; text-align: center; display: flex; flex-direction: column; justify-content: center; min-height: 56px; }
    .preview-option-item.active { border-color: #d70018; background: #fff5f5; box-shadow: 0 0 0 1px #d70018; }
    
    /* IN-PAGE PREVIEW SECTION STYLING */
    #livePreviewSection {
        background: #f8fafc;
        border-radius: 32px;
        padding: 60px 40px;
        margin-top: 50px;
        box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
    }

    #previewContent {
        max-width: 1300px;
        margin: 0 auto;
    }

    .preview-card-inner {
        background: #fff;
        border-radius: 24px;
        padding: 50px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
        width: 100%;
    }

    .preview-img-container {
        background: #fafafa;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px;
        min-height: 500px;
        border: 1px solid #f0f0f0;
    }

    .preview-img-container img {
        max-width: 100%;
        max-height: 600px;
        object-fit: contain;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">🛍️ Thêm Sản Phẩm (CellphoneS Style)</h2>
    <a asp-action="Index" class="btn btn-light shadow-sm border rounded-pill px-4 fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger shadow-sm border-0 rounded-3">
        <div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle-fill me-1"></i> Vui lòng kiểm tra lại dữ liệu:</div>
        <ul class="mb-0 small">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form asp-action="Create" method="post" enctype="multipart/form-data" id="productForm">
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-lg-12">
            <!-- ===== CHỌN LOẠI SẢN PHẨM & TRẠNG THÁI ===== -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-danger"><i class="bi bi-grid-1x2-fill me-2"></i>Cấu hình sản phẩm</h5>
                    <div class="form-check form-switch border p-2 px-4 rounded-pill bg-light">
                        <input class="form-check-input ms-0 me-2" type="checkbox" asp-for="IsActive" id="statusToggle" checked>
                        <label class="form-check-label fw-bold text-success" for="statusToggle" id="statusLabel">Trạng thái: Đang bán</label>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <input type="radio" class="btn-check" asp-for="ProductType" id="typeVersions" value="1" checked>
                            <label class="btn btn-outline-primary w-100 py-3 rounded-3 text-start" for="typeVersions">
                                <strong>Dung lượng</strong>
                                <div class="small mt-1">iPhone, Laptop...</div>
                            </label>
                        </div>
                        <div class="col-md-6">
                            <input type="radio" class="btn-check" asp-for="ProductType" id="typeColors" value="2">
                            <label class="btn btn-outline-success w-100 py-3 rounded-3 text-start" for="typeColors">
                                <strong>Chỉ màu sắc</strong>
                                <div class="small mt-1">Loa, Tai nghe...</div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Thông tin chung -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-info-circle-fill me-2"></i>Thông tin chung của sản phẩm</h5>
                    <p class="text-muted small mt-1">Thông tin hiển thị trên trang sản phẩm.</p>
                </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold text-muted small">Tên sản phẩm (Model) <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control bg-light border-0" placeholder="VD: iPhone 15 Pro Max" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="CategoryId" class="form-label fw-bold text-muted small">Danh mục <span class="text-danger">*</span></label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select bg-light border-0">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="BrandId" class="form-label fw-bold text-muted small">Thương hiệu</label>
                        <select asp-for="BrandId" asp-items="ViewBag.Brands" class="form-select bg-light border-0">
                            <option value="">-- Chọn thương hiệu --</option>
                        </select>
                    </div>

                    <!-- Giá trực tiếp – hiện khi ColorsOnly -->
                    <div class="col-md-3" id="directPriceSection" style="display:none;">
                        <label asp-for="Price" class="form-label fw-bold text-muted small">Giá bán (₫) <span class="text-danger">*</span></label>
                        <input asp-for="Price" type="number" class="form-control bg-light border-0" placeholder="VD: 1090000" min="0" />
                    </div>
                    <div class="col-md-3" id="directOriginalPriceSection" style="display:none;">
                        <label asp-for="OriginalPrice" class="form-label fw-bold text-muted small">Giá gốc (₫) - Khuyến mãi</label>
                        <input asp-for="OriginalPrice" type="number" class="form-control bg-light border-0" placeholder="VD: 1290000" min="0" />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="ImageFile" class="form-label fw-bold text-muted small">Ảnh đại diện (Thumbnail) <span class="text-danger">*</span></label>
                        <input asp-for="ImageFile" type="file" class="form-control bg-light border-0" accept="image/*" required />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="GalleryFiles" class="form-label fw-bold text-muted small">Hình ảnh bổ sung (Gallery)</label>
                        <input asp-for="GalleryFiles" type="file" multiple class="form-control bg-light border-0" accept="image/*" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-bold text-muted small">Mô tả tổng quát (Tùy chọn)</label>
                        <textarea asp-for="Description" class="form-control bg-light border-0" rows="2" placeholder="Thông tin giới thiệu chung..."></textarea>
                    </div>
                </div>
            </div>
        </div>

    <!-- ===== SECTION: Có phiên bản dung lượng ===== -->
    <div id="sectionVersions">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0"><i class="bi bi-stack me-2"></i>Danh sách các phiên bản Dung lượng</h5>
            <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold" onclick="addVersion()">
                <i class="bi bi-plus-lg me-1"></i> Thêm dung lượng mới
            </button>
        </div>
        <div id="versionsContainer">
            <div class="text-center p-5 bg-white rounded-4 shadow-sm mb-4 border border-dashed" id="noVersionHint">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <p class="mt-2 text-muted">Sản phẩm này chưa có phiên bản dung lượng nào. Hãy bấm nút phía trên để thêm.</p>
            </div>
        </div>
    </div>

    <!-- ===== SECTION: Chỉ có màu sắc ===== -->
    <div id="sectionColors" style="display:none;">
        <!-- Hidden inputs for the default version required by model binder -->
        <input type="hidden" name="Versions[0].Name" value="Mặc định" />
        <input type="hidden" name="Versions[0].BasePrice" value="0" />
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="fw-bold mb-0 text-success"><i class="bi bi-palette-fill me-2"></i>Màu sắc và Tồn kho</h5>
                    <p class="text-muted small mt-1">Giá của mỗi màu sẽ dùng giá chung bên trên, hoặc nhập riêng nếu khác giá.</p>
                </div>
                <button type="button" class="btn btn-success rounded-pill px-3" onclick="addColorVariant()">
                    <i class="bi bi-plus-lg me-1"></i> Thêm màu
                </button>
            </div>
            <div class="card-body p-4">
                <div id="colorVariantsContainer" class="d-flex flex-column gap-2"></div>
                <div class="text-center py-3 text-muted small" id="noColorHint">Chưa có màu nào. Bấm "Thêm màu" để thêm.</div>
            </div>
        </div>

        <!-- Thông số kỹ thuật cho Chỉ màu sắc -->
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="fw-bold mb-0 text-success"><i class="bi bi-list-task me-2"></i>Thông số kỹ thuật</h5>
                    <p class="text-muted small mt-1">Các thông số kỹ thuật của sản phẩm (ví dụ: Công suất, Thời lượng pin...)</p>
                </div>
                <button type="button" class="btn btn-success rounded-pill px-3" onclick="addColorSpec()">
                    <i class="bi bi-plus-lg me-1"></i> Thêm thông số
                </button>
            </div>
            <div class="card-body p-4">
                <div id="colorSpecsContainer" class="d-flex flex-column gap-2"></div>
                <div class="text-center py-3 text-muted small" id="noColorSpecHint">Chưa có thông số nào. Bấm "Thêm thông số" để thêm.</div>
            </div>
        </div>
    </div>

        </div>
    </div>

    <div class="sticky-bottom bg-white border-top p-3 mt-4 text-end rounded-top-4 shadow-lg d-flex justify-content-end gap-3" style="z-index: 1000;">
        <button type="button" class="btn btn-outline-primary btn-lg px-4 rounded-pill fw-bold shadow-sm" onclick="showPreview()">
            <i class="bi bi-eye-fill me-2"></i> XEM TRƯỚC GIAO DIỆN
        </button>
        <button type="submit" class="btn btn-danger btn-lg px-5 rounded-pill fw-bold shadow">
            <i class="bi bi-cloud-upload-fill me-2"></i> LƯU TẤT CẢ THÔNG TIN
        </button>
    </div>
</form>

<!-- Phần Xem trước trực tiếp tại trang -->
<div id="livePreviewSection" style="display: none;">
    <div class="d-flex align-items-center mb-5">
        <div class="flex-grow-1 h-px bg-secondary opacity-10"></div>
        <h2 class="mx-4 fw-bold text-dark"><i class="bi bi-display me-2 text-primary"></i>BẢN XEM TRƯỚC GIAO DIỆN NGƯỜI DÙNG</h2>
        <div class="flex-grow-1 h-px bg-secondary opacity-10"></div>
    </div>
    
    <div id="previewContent">
        <!-- Nội dung sẽ được đổ vào đây -->
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        // Initialize sections on load
        document.addEventListener('DOMContentLoaded', function() {
            // In Create view, we usually start with one version by default if nothing is selected
            const checkedRadio = document.querySelector('input[name="ProductType"]:checked');
            if (!checkedRadio) {
                // If nothing checked, default to Versions (1)
                const radioVersions = document.getElementById('typeVersions');
                if (radioVersions) radioVersions.checked = true;
                addVersion();
            } else if (checkedRadio.value === '1') {
                // If Versions is checked but container is empty, add one
                if (document.getElementById('versionsContainer').children.length === 0 || 
                    (document.getElementById('versionsContainer').children.length === 1 && 
                     document.getElementById('noVersionHint')?.style.display !== 'none')) {
                    addVersion();
                }
            }
            
            updateSections();
            
            // Add event listeners to radio buttons
            document.querySelectorAll('input[name="ProductType"]').forEach(radio => {
                radio.addEventListener('change', updateSections);
            });

            // Status Toggle interaction
            const statusToggle = document.getElementById('statusToggle');
            const statusLabel = document.getElementById('statusLabel');
            if (statusToggle && statusLabel) {
                statusToggle.addEventListener('change', function() {
                    if (this.checked) {
                        statusLabel.innerText = "Trạng thái: Đang bán";
                        statusLabel.className = "form-check-label fw-bold text-success";
                    } else {
                        statusLabel.innerText = "Trạng thái: Hết hàng";
                        statusLabel.className = "form-check-label fw-bold text-danger";
                    }
                });
            }

            // Form submit reindexing
            const productForm = document.getElementById('productForm');
            if (productForm) {
                productForm.addEventListener('submit', function() {
                    reindexForm();
                });
            }
        });

        // Backup window.onload
        window.addEventListener('load', updateSections);

        function updateSections() {
            const checkedRadio = document.querySelector('input[name="ProductType"]:checked');
            const val = checkedRadio?.value;
            
            const sectionVersions  = document.getElementById('sectionVersions');
            const sectionColors    = document.getElementById('sectionColors');
            const directPrice      = document.getElementById('directPriceSection');
            const directOrig       = document.getElementById('directOriginalPriceSection');

            // Determine visibility
            let isHasVersions = (val === '1' || val === 'HasVersions');
            let isColorsOnly  = (val === '2' || val === 'ColorsOnly');
            
            // Fallback if val is missing on load
            if (!val) {
                const hasCheckedAttr = document.querySelector('input[name="ProductType"][checked]');
                if (hasCheckedAttr) {
                    const attrVal = hasCheckedAttr.value;
                    isHasVersions = (attrVal === '1' || attrVal === 'HasVersions');
                    isColorsOnly = (attrVal === '2' || attrVal === 'ColorsOnly');
                } else {
                    // Default for Create
                    isHasVersions = true; 
                }
            }

            if (sectionVersions) sectionVersions.style.display = isHasVersions ? 'block' : 'none';
            if (sectionColors) sectionColors.style.display   = isColorsOnly   ? 'block' : 'none';
            if (directPrice) directPrice.style.display     = isColorsOnly   ? 'block' : 'none';
            if (directOrig) directOrig.style.display      = isColorsOnly   ? 'block' : 'none';

            // Disable inputs in hidden sections
            toggleSectionInputs('sectionVersions', isHasVersions);
            toggleSectionInputs('sectionColors', isColorsOnly);
        }

        function toggleSectionInputs(sectionId, enabled) {
            const section = document.getElementById(sectionId);
            if (!section) return;
            section.querySelectorAll('input, textarea, select').forEach(el => {
                el.disabled = !enabled;
            });
        }

        function removeRow(id) {
            const el = document.getElementById(id);
            if (el) el.remove();
        }

        // ===== THÊM MÀU SẮC (cho ColorsOnly) =====
        let colorCount = 0;
        function addColorVariant() {
            const container = document.getElementById('colorVariantsContainer');
            const hint      = document.getElementById('noColorHint');
            if (hint) hint.style.display = 'none';
            const idx = colorCount++;
            container.insertAdjacentHTML('beforeend', `
            <div class="bg-white p-3 rounded-3 border shadow-sm position-relative mb-2" id="colorRow_${idx}">
                <button type="button" class="btn btn-sm btn-light text-danger position-absolute top-0 end-0 m-2 rounded-circle"
                    onclick="removeRow('colorRow_${idx}')"><i class="bi bi-trash"></i></button>
                <div class="row g-2 align-items-end pe-4">
                    <div class="col-md-4">
                        <label class="form-label tiny-label fw-bold text-muted mb-1" style="font-size:10px">Màu sắc *</label>
                        <input type="text" name="Versions[0].Variants[${idx}].Color"
                               class="form-control form-control-sm" placeholder="VD: Đen" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label tiny-label fw-bold text-muted mb-1" style="font-size:10px">Giá riêng (₫) – 0 = dùng giá chung</label>
                        <input type="number" name="Versions[0].Variants[${idx}].Price"
                               class="form-control form-control-sm" value="0" min="0" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label tiny-label fw-bold text-muted mb-1" style="font-size:10px">Tồn kho</label>
                        <input type="number" name="Versions[0].Variants[${idx}].Stock"
                               class="form-control form-control-sm" value="0" min="0" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label tiny-label fw-bold text-muted mb-1" style="font-size:10px">Ảnh màu</label>
                        <input type="file" name="Versions[0].Variants[${idx}].ImageFile"
                               class="form-control form-control-sm" accept="image/*" />
                    </div>
                </div>
            </div>`);
        }

        // ===== THÊM THÔNG SỐ (cho ColorsOnly) =====
        let colorSpecCount = 0;
        function addColorSpec() {
            const container = document.getElementById('colorSpecsContainer');
            const hint      = document.getElementById('noColorSpecHint');
            if (hint) hint.style.display = 'none';
            const idx = colorSpecCount++;
            container.insertAdjacentHTML('beforeend', `
            <div class="row g-1 bg-white p-2 rounded-3 border mb-1" id="colorSpec_${idx}">
                <div class="col-5">
                    <input type="text" name="Versions[0].Specifications[${idx}].SpecName" class="form-control form-control-sm border-light" placeholder="Tên (VD: Pin)" required />
                </div>
                <div class="col-6">
                    <input type="text" name="Versions[0].Specifications[${idx}].SpecValue" class="form-control form-control-sm border-light" placeholder="Giá trị (VD: 10 giờ)" required />
                </div>
                <div class="col-1 text-center">
                    <button type="button" class="btn btn-sm text-danger border-0 p-0" onclick="removeRow('colorSpec_${idx}')"><i class="bi bi-x-circle-fill"></i></button>
                </div>
            </div>`);
        }

        let versionCount = 0;

        function addVersion() {
            const container = document.getElementById('versionsContainer');
            const hint = document.getElementById('noVersionHint');
            if (hint) hint.style.display = 'none';

            const vIdx = versionCount++;
            const vHtml = `
            <div class="card shadow-sm border-0 rounded-4 mb-4 version-card" id="version_${vIdx}">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="fw-bold text-primary mb-1">Phiên bản dung lượng #${vIdx + 1}</h6>
                        <span class="badge bg-primary rounded-pill">Version</span>
                    </div>
                    <button type="button" class="btn btn-outline-danger btn-remove rounded-circle" onclick="removeRow('version_${vIdx}')">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
                <div class="card-body p-4">
                    <!-- Thông tin dung lượng -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-muted">Tên dung lượng <span class="text-danger">*</span></label>
                            <input type="text" name="Versions[${vIdx}].Name" class="form-control bg-light border-0 fw-bold" placeholder="VD: 256GB" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-muted">Giá cơ bản cho dung lượng này (₫) <span class="text-danger">*</span></label>
                            <input type="number" name="Versions[${vIdx}].BasePrice" class="form-control bg-light border-0" placeholder="0" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-muted">Ảnh đại diện dung lượng</label>
                            <input type="file" name="Versions[${vIdx}].ImageFile" class="form-control form-control-sm border-0 bg-light" accept="image/*" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small text-muted">Đặc điểm nổi bật (Cho riêng bản này)</label>
                            <textarea name="Versions[${vIdx}].Description" class="form-control bg-light border-0" rows="3" placeholder="Nhập các đặc điểm nổi bật riêng của phiên bản này..."></textarea>
                        </div>
                    </div>

                    <div class="row g-4">
                        <!-- Cột Màu sắc -->
                        <div class="col-lg-7">
                            <div class="card nested-card rounded-3 h-100">
                                <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                                    <span class="fw-bold small text-dark"><i class="bi bi-palette me-2"></i>Các màu sắc & Tồn kho</span>
                                    <button type="button" class="btn btn-sm btn-white border shadow-sm rounded-pill px-3" onclick="addVariant(${vIdx})">
                                        <i class="bi bi-plus-lg me-1"></i> Thêm màu
                                    </button>
                                </div>
                                <div class="card-body pt-0">
                                    <div id="variantsContainer_${vIdx}" class="d-flex flex-column gap-2">
                                        <!-- Variants list -->
                                    </div>
                                    <div class="text-center py-4 text-muted small" id="noVariantHint_${vIdx}">Chưa có màu sắc nào được thêm.</div>
                                </div>
                            </div>
                        </div>

                        <!-- Cột Thông số -->
                        <div class="col-lg-5">
                            <div class="card nested-card rounded-3 h-100">
                                <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                                    <span class="fw-bold small text-dark"><i class="bi bi-list-task me-2"></i>Thông số kỹ thuật</span>
                                    <button type="button" class="btn btn-sm btn-white border shadow-sm rounded-pill px-3" onclick="addSpec(${vIdx})">
                                        <i class="bi bi-plus-lg me-1"></i> Thêm thông số
                                    </button>
                                </div>
                                <div class="card-body pt-0">
                                    <div id="specsContainer_${vIdx}" class="d-flex flex-column gap-2">
                                        <!-- Specs list -->
                                    </div>
                                    <div class="text-center py-4 text-muted small" id="noSpecHint_${vIdx}">Chưa có thông số nào.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            `;
            container.insertAdjacentHTML('beforeend', vHtml);
        }

        let variantCounters = {};
        function addVariant(vIdx) {
            const container = document.getElementById(`variantsContainer_${vIdx}`);
            const hint = document.getElementById(`noVariantHint_${vIdx}`);
            if (hint) hint.style.display = 'none';

            if (!variantCounters[vIdx]) variantCounters[vIdx] = 0;
            const varIdx = variantCounters[vIdx]++;

            const html = `
            <div class="bg-white p-3 rounded-3 border shadow-xs position-relative mb-2" id="variant_${vIdx}_${varIdx}">
                <button type="button" class="btn btn-sm btn-light text-danger position-absolute top-0 end-0 m-2 rounded-circle" onclick="removeRow('variant_${vIdx}_${varIdx}')"><i class="bi bi-trash"></i></button>
                <div class="row g-2 align-items-end pe-4">
                    <div class="col-md-4">
                        <label class="form-label tiny-label fw-bold text-muted mb-1" style="font-size: 10px;">Màu sắc</label>
                        <input type="text" name="Versions[${vIdx}].Variants[${varIdx}].Color" class="form-control form-control-sm border-light" placeholder="VD: Titan Đen" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label tiny-label fw-bold text-muted mb-1" style="font-size: 10px;">Giá (₫) - 0 để dùng giá cơ bản</label>
                        <input type="number" name="Versions[${vIdx}].Variants[${varIdx}].Price" class="form-control form-control-sm border-light" value="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label tiny-label fw-bold text-muted mb-1" style="font-size: 10px;">Tồn kho</label>
                        <input type="number" name="Versions[${vIdx}].Variants[${varIdx}].Stock" class="form-control form-control-sm border-light" value="0" />
                    </div>
                    <div class="col-12 mt-2">
                        <label class="form-label tiny-label fw-bold text-muted mb-1" style="font-size: 10px;">Ảnh màu sắc</label>
                        <input type="file" name="Versions[${vIdx}].Variants[${varIdx}].ImageFile" class="form-control form-control-sm border-light" accept="image/*" />
                    </div>
                </div>
            </div>`;
            container.insertAdjacentHTML('beforeend', html);
        }

        let specCounters = {};
        function addSpec(vIdx) {
            const container = document.getElementById(`specsContainer_${vIdx}`);
            const hint = document.getElementById(`noSpecHint_${vIdx}`);
            if (hint) hint.style.display = 'none';

            if (!specCounters[vIdx]) specCounters[vIdx] = 0;
            const sIdx = specCounters[vIdx]++;

            const html = `
            <div class="row g-1 bg-white p-2 rounded-3 border shadow-xs mb-1" id="spec_${vIdx}_${sIdx}">
                <div class="col-5">
                    <input type="text" name="Versions[${vIdx}].Specifications[${sIdx}].SpecName" class="form-control form-control-sm border-light" placeholder="Tên (VD: Màn hình)" required />
                </div>
                <div class="col-6">
                    <input type="text" name="Versions[${vIdx}].Specifications[${sIdx}].SpecValue" class="form-control form-control-sm border-light" placeholder="Giá trị (VD: 6.7 inch)" required />
                </div>
                <div class="col-1 text-center">
                    <button type="button" class="btn btn-sm text-danger border-0 p-0" onclick="removeRow('spec_${vIdx}_${sIdx}')"><i class="bi bi-x-circle-fill"></i></button>
                </div>
            </div>`;
            container.insertAdjacentHTML('beforeend', html);
        }

        function showPreview() {
            const productName = document.querySelector('input[name="Name"]').value || "Tên sản phẩm";
            const description = document.querySelector('textarea[name="Description"]').value || "Mô tả sản phẩm...";
            
            // More robust way to get product type
            let checkedRadio = document.querySelector('input[name="ProductType"]:checked');
            if (!checkedRadio) {
                // Fallback to searching for the one with 'checked' attribute
                checkedRadio = document.querySelector('input[name="ProductType"][checked]');
            }
            
            let productType = checkedRadio?.value;
            
            // Final fallback: if still nothing, try to infer from section visibility
            if (!productType) {
                if (document.getElementById('sectionVersions')?.style.display === 'block') productType = '1';
                else if (document.getElementById('sectionColors')?.style.display === 'block') productType = '2';
            }

            const imageFileInput = document.querySelector('input[name="ImageFile"]');
            let imageUrl = '';
            if (imageFileInput && imageFileInput.files && imageFileInput.files[0]) {
                imageUrl = URL.createObjectURL(imageFileInput.files[0]);
            }

            let html = '';
            // Robust check for product type
            if (productType === "1" || productType === "HasVersions") {
                const versionElements = document.querySelectorAll('.version-card');
                let tabsHtml = ''; let tabContentsHtml = '';
                
                if (versionElements.length === 0) {
                    html = '<div class="alert alert-warning text-center rounded-4 py-4"><i class="bi bi-info-circle me-2"></i>Chưa có phiên bản nào để xem trước.</div>';
                } else {
                    versionElements.forEach((vEl, vIdx) => {
                        const vName = vEl.querySelector('input[name*=".Name"]')?.value || `Dung lượng ${vIdx+1}`;
                        const vPrice = parseFloat(vEl.querySelector('input[name*=".BasePrice"]')?.value || '0');
                        const vImgInput = vEl.querySelector('input[name*=".ImageFile"]');
                        let vImgUrl = imageUrl;
                        if (vImgInput && vImgInput.files && vImgInput.files[0]) {
                            vImgUrl = URL.createObjectURL(vImgInput.files[0]);
                        }

                        let varsHtml = '';
                        const variants = vEl.querySelectorAll('[id^="variant_"]');
                        variants.forEach((vr, i) => {
                            const color = vr.querySelector('input[name*=".Color"]')?.value || 'Màu';
                            const price = parseFloat(vr.querySelector('input[name*=".Price"]')?.value || '0');
                            varsHtml += `<div class="preview-option-item ${i===0?'active':''}"><span class="fw-bold small">${color}</span><small>${(price > 0 ? price : vPrice).toLocaleString('vi-VN')}₫</small></div>`;
                        });
                        tabsHtml += `<button type="button" class="btn ${vIdx===0?'btn-danger':'btn-outline-secondary'} btn-sm rounded-pill px-3 me-2 mb-2" onclick="switchPreviewTab(${vIdx}, ${versionElements.length})" id="ptab_${vIdx}">${vName}</button>`;
                        tabContentsHtml += `<div id="ptabContent_${vIdx}" style="display:${vIdx===0?'block':'none'}">${buildInnerHtml(productName, vName, vPrice, 0, varsHtml, description, vImgUrl)}</div>`;
                    });
                    html = `<div class="mb-4 d-flex justify-content-center flex-wrap">${tabsHtml}</div>${tabContentsHtml}`;
                }
            } else {
                const p = parseFloat(document.querySelector('input[name="Price"]').value || '0'), op = parseFloat(document.querySelector('input[name="OriginalPrice"]').value || '0');
                let varsHtml = '';
                if (productType === "2" || productType === "ColorsOnly") {
                    [...document.querySelectorAll('[id^="colorRow_"]')].forEach((row, i) => {
                        const color = row.querySelector('input[name*=".Color"]')?.value || 'Màu';
                        const vp = parseFloat(row.querySelector('input[name*=".Price"]')?.value || '0');
                        varsHtml += `<div class="preview-option-item ${i===0?'active':''}"><span class="fw-bold small">${color}</span><small>${(vp > 0 ? vp : p).toLocaleString('vi-VN')}₫</small></div>`;
                    });
                }
                html = buildInnerHtml(productName, "", p, op, varsHtml, description, imageUrl);
            }

            const previewSection = document.getElementById('livePreviewSection');
            document.getElementById('previewContent').innerHTML = html;
            previewSection.style.display = 'block';
            previewSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function buildInnerHtml(n, sn, p, op, vh, d, img) {
            const ph = (op > p) ? `<div class="preview-current-price">${p.toLocaleString('vi-VN')}₫</div><del class="text-muted ms-2 small">${op.toLocaleString('vi-VN')}₫</del>` : `<div class="preview-current-price">${p.toLocaleString('vi-VN')}₫</div>`;
            const imgHtml = img ? `<img src="${img}" class="img-fluid rounded-4" style="max-height:300px; object-fit:contain;">` : `<i class="bi bi-image fs-1 text-muted"></i>`;
            return `<div class="preview-card-inner border p-4 bg-white rounded-4 shadow-sm">
                <div class="row gx-4">
                    <div class="col-lg-5 text-center bg-light rounded-4 py-5 mb-4 mb-lg-0 d-flex align-items-center justify-content-center">${imgHtml}</div>
                    <div class="col-lg-7 px-lg-5">
                        <h3 class="fw-bold">${n}</h3>
                        ${sn?`<p class="text-muted">${sn}</p>`:''}
                        <div class="d-flex align-items-center mb-4">${ph}</div>
                        ${vh?`<div class="mb-4"><label class="small fw-bold d-block mb-2">Lựa chọn màu sắc:</label><div class="d-flex flex-wrap gap-2">${vh}</div></div>`:''}
                        <div class="border-top pt-3">
                            <label class="small fw-bold d-block mb-1">Mô tả tóm tắt:</label>
                            <div class="small text-muted" style="white-space:pre-wrap">${d || 'Mô tả sản phẩm...'}</div>
                        </div>
                    </div>
                </div>
            </div>`;
        }

        function switchPreviewTab(activeIdx, total) {
            for(let i=0;i<total;i++) {
                const content = document.getElementById(`ptabContent_${i}`);
                const btn = document.getElementById(`ptab_${i}`);
                if(content) content.style.display = i===activeIdx ? 'block' : 'none';
                if(btn) { btn.classList.toggle('btn-danger', i===activeIdx); btn.classList.toggle('btn-outline-secondary', i!==activeIdx); }
            }
        }

        function reindexForm() {
            let checkedRadio = document.querySelector('input[name="ProductType"]:checked');
            let productType = checkedRadio ? checkedRadio.value : "1";
            
            if (productType === "1" || productType === "HasVersions") {
                // Re-index Versions
                const versionCards = document.querySelectorAll('#versionsContainer .version-card');
                versionCards.forEach((vCard, vIdx) => {
                    // Update all inputs in this version card to use the correct vIdx
                    const inputs = vCard.querySelectorAll('input, textarea, select');
                    inputs.forEach(input => {
                        let name = input.getAttribute('name');
                        if (name) {
                            name = name.replace(/Versions\[\d+\]/, `Versions[${vIdx}]`);
                            input.setAttribute('name', name);
                        }
                    });

                    // Re-index Variants inside this version
                    const variantRows = vCard.querySelectorAll('[id^="variant_"]');
                    variantRows.forEach((vRow, vrIdx) => {
                        const vInputs = vRow.querySelectorAll('input, select, textarea');
                        vInputs.forEach(input => {
                            let name = input.getAttribute('name');
                            if (name) {
                                name = name.replace(/Variants\[\d+\]/, `Variants[${vrIdx}]`);
                                input.setAttribute('name', name);
                            }
                        });
                    });

                    // Re-index Specifications inside this version
                    const specRows = vCard.querySelectorAll('[id^="spec_"]');
                    specRows.forEach((sRow, sIdx) => {
                        const sInputs = sRow.querySelectorAll('input, select, textarea');
                        sInputs.forEach(input => {
                            let name = input.getAttribute('name');
                            if (name) {
                                name = name.replace(/Specifications\[\d+\]/, `Specifications[${sIdx}]`);
                                input.setAttribute('name', name);
                            }
                        });
                    });
                });
            } else {
                // ColorsOnly
                // Re-index Variants inside colorVariantsContainer
                const colorRows = document.querySelectorAll('#colorVariantsContainer [id^="colorRow_"], #colorVariantsContainer tr');
                colorRows.forEach((cRow, vrIdx) => {
                    const cInputs = cRow.querySelectorAll('input, select, textarea');
                    cInputs.forEach(input => {
                        let name = input.getAttribute('name');
                        if (name) {
                            name = name.replace(/Versions\[\d+\]\.Variants\[\d+\]/, `Versions[0].Variants[${vrIdx}]`);
                            input.setAttribute('name', name);
                        }
                    });
                });

                // Re-index Specifications inside colorSpecsContainer
                const specRows = document.querySelectorAll('#colorSpecsContainer [id^="colorSpec_"]');
                specRows.forEach((sRow, sIdx) => {
                    const sInputs = sRow.querySelectorAll('input, select, textarea');
                    sInputs.forEach(input => {
                        let name = input.getAttribute('name');
                        if (name) {
                            name = name.replace(/Versions\[\d+\]\.Specifications\[\d+\]/, `Versions[0].Specifications[${sIdx}]`);
                            input.setAttribute('name', name);
                        }
                    });
                });
            }
        }
    </script>
}