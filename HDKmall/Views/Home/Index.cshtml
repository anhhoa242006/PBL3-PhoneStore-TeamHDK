@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Trust Bar -->
<div style="background:#d70018; color:#fff; padding:8px 0; border-bottom:1px solid rgba(255,255,255,.15);">
    <div class="container">
        <div class="row g-0 text-center" style="font-size:13px;">
            <div class="col-6 col-md-3 py-1 d-flex align-items-center justify-content-center gap-2">
                <span style="font-size:18px;">🚚</span>
                <span>Giao hàng toàn quốc</span>
            </div>
            <div class="col-6 col-md-3 py-1 d-flex align-items-center justify-content-center gap-2">
                <span style="font-size:18px;">🛡️</span>
                <span>Bảo hành chính hãng 12 tháng</span>
            </div>
            <div class="col-6 col-md-3 py-1 d-flex align-items-center justify-content-center gap-2">
                <span style="font-size:18px;">🔄</span>
                <span>Đổi trả 30 ngày</span>
            </div>
            <div class="col-6 col-md-3 py-1 d-flex align-items-center justify-content-center gap-2">
                <span style="font-size:18px;">✅</span>
                <span>100% hàng chính hãng</span>
            </div>
        </div>
    </div>
</div>

<!-- Hero Banner -->
<div id="heroCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
    @if (ViewBag.Banners != null && ((IEnumerable<HDKmall.Models.Banner>)ViewBag.Banners).Any())
    {
        var banners = ((IEnumerable<HDKmall.Models.Banner>)ViewBag.Banners).ToList();
        var gradients = new string[] { 
            "linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%)", 
            "linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)", 
            "linear-gradient(135deg, #111 0%, #333 100%)",
            "linear-gradient(135deg, #667eea 0%, #764ba2 100%)" 
        };
        var textColors = new string[] { "text-white", "text-white", "text-white", "text-white" };
        var btnClasses = new string[] { "btn-light text-danger", "btn-light text-primary", "btn-light text-dark", "btn-light text-purple" };
        var defaultBadgeClasses = new string[] { "bg-danger", "bg-info text-dark", "bg-white text-dark", "bg-warning text-dark" };

        <div class="carousel-indicators">
            @for (int i = 0; i < banners.Count; i++)
            {
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
            }
        </div>
        <div class="carousel-inner rounded-4 shadow">
            @for (int i = 0; i < banners.Count; i++)
            {
                var banner = banners[i];
                var cIdx = i % 4;
                <div class="carousel-item @(i == 0 ? "active" : "") position-relative" style="height: 450px; background: @gradients[cIdx];">
                    <div class="container h-100 position-relative z-1 d-flex align-items-center">
                        <div class="@textColors[cIdx] w-50 pe-4">
                            @if (!string.IsNullOrEmpty(banner.BadgeText))
                            {
                                <span class="badge @defaultBadgeClasses[cIdx] mb-3 fs-6">@banner.BadgeText</span>
                            }
                            <h1 class="display-4 fw-bold mb-3">@(string.IsNullOrEmpty(banner.Title) ? "Khám phá ngay" : banner.Title)</h1>
                            @if (!string.IsNullOrEmpty(banner.Description))
                            {
                                <p class="lead mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">@banner.Description</p>
                            }
                            @if (!string.IsNullOrEmpty(banner.LinkUrl))
                            {
                                <a href="@banner.LinkUrl" class="btn @btnClasses[cIdx] fw-bold rounded-pill px-4 py-2 fs-5">@(string.IsNullOrEmpty(banner.ButtonText) ? "Khám phá ngay" : banner.ButtonText)</a>
                            }
                        </div>
                        <div class="w-50 h-100 d-flex justify-content-center align-items-center py-3">
                            <img src="@(string.IsNullOrEmpty(banner.ImageUrl) ? "/img/promo_default.jpg" : banner.ImageUrl)" class="img-fluid" style="max-height: 100%; object-fit: contain; filter: drop-shadow(0 20px 30px rgba(0,0,0,0.2));" alt="@banner.Title" onerror="this.onerror=null; this.src='/img/promo_default.jpg';">
                        </div>
                    </div>
                    <!-- Abstract background shape -->
                    <div class="position-absolute end-0 top-0 h-100 w-50" style="background: url('https://placehold.co/600x450/ffffff/ffffff') no-repeat center/cover; opacity: 0.1;"></div>
                </div>
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev" style="z-index: 10;">
            <span class="carousel-control-prev-icon" aria-hidden="true" style="width: 3rem; height: 3rem;"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next" style="z-index: 10;">
            <span class="carousel-control-next-icon" aria-hidden="true" style="width: 3rem; height: 3rem;"></span>
            <span class="visually-hidden">Next</span>
        </button>
    }
    else
    {
        <div class="carousel-inner rounded-4 shadow">
            <div class="carousel-item active position-relative" style="height: 450px; background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);">
                <div class="container h-100 position-relative z-1 d-flex align-items-center">
                    <div class="text-white w-50">
                        <h1 class="display-3 fw-bold mb-3">Chào mừng đến với HDKmall</h1>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Categories -->
<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <h3 class="fw-bold mb-0">Danh mục nổi bật</h3>
        <a href="/Product" class="text-decoration-none text-primary fw-medium">Xem tất cả <i class="bi bi-arrow-right"></i></a>
    </div>
    
    <div class="row row-cols-2 row-cols-md-4 g-3">
        @if (ViewBag.Categories != null)
        {
            foreach (var cat in ViewBag.Categories)
            {
                string currentIcon = "bi-tag"; // Mặc định
                string catName = ((string)cat.Name).ToLower();
                
                if (catName.Contains("điện thoại")) currentIcon = "bi-phone";
                else if (catName.Contains("laptop") || catName.Contains("máy tính xách tay")) currentIcon = "bi-laptop";
                else if (catName.Contains("máy tính bảng") || catName.Contains("tablet")) currentIcon = "bi-tablet";
                else if (catName.Contains("tai nghe")) currentIcon = "bi-headphones";
                else if (catName.Contains("đồng hồ") || catName.Contains("watch")) currentIcon = "bi-smartwatch";
                else if (catName.Contains("phụ kiện")) currentIcon = "bi-cpu";
                else if (catName.Contains("camera") || catName.Contains("máy ảnh")) currentIcon = "bi-camera";
                else if (catName.Contains("loa") || catName.Contains("âm thanh")) currentIcon = "bi-speaker";
                else if (catName.Contains("game") || catName.Contains("controller")) currentIcon = "bi-controller";

                <div class="col mt-2 mb-2">
                    <a href="/Product?categoryId=@cat.Id" class="text-decoration-none">
                        <div class="card border-0 shadow-sm rounded-4 h-100 text-center py-4 hover-up bg-light">
                            <div class="card-body">
                                <i class="bi @currentIcon text-primary mb-3 d-block" style="font-size: 3rem;"></i>
                                <h6 class="card-title text-dark fw-bold mb-0">@cat.Name</h6>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</div>

<style>
    .transition-all { transition: all 0.3s ease; }
    .hover-up { transition: all 0.3s ease; }
    .hover-up:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; border: 1px solid var(--bs-primary) !important; background-color: #fff !important; }
    .product-card-hover { transition: all 0.3s ease; }
    .product-card-hover:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important; border-color: rgba(13, 110, 253, 0.25) !important; }
    .home-wishlist-btn { background:none; border:none; padding:0; cursor:pointer; color:#ccc; font-size:17px; transition:color .2s; display:flex; align-items:center; gap:3px; }
    .home-wishlist-btn:hover, .home-wishlist-btn.active { color:#d70018; }
    .home-wishlist-btn .wl-label { font-size:11px; color:#aaa; }
    .home-wishlist-btn.active .wl-label { color:#d70018; }
</style>

@* Hidden form for CSRF token (used by AJAX add-to-cart) *@
<form id="csrf-form" style="display:none">@Html.AntiForgeryToken()</form>

<!-- Featured Products -->
<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <h3 class="fw-bold mb-0">🔥 Sản phẩm nổi bật</h3>
        <a href="/Product" class="text-decoration-none text-danger fw-medium">Xem thêm <i class="bi bi-arrow-right"></i></a>
    </div>
    
    <div class="row row-cols-2 row-cols-lg-4 g-4 border border-1 border-light">
        @if (ViewBag.FeaturedProducts != null)
        {
            foreach (HDKmall.ViewModels.ProductListVM item in ViewBag.FeaturedProducts)
            {
                <div class="col">
                    <div class="card h-100 border border-light shadow-sm rounded-4 overflow-hidden product-card-hover position-relative">
                        @if (item.DiscountPercent > 0)
                        {
                            <span class="position-absolute top-0 start-0 m-3 badge bg-danger rounded-pill fw-bold z-1" style="font-size: 0.75rem;">Giảm @(item.DiscountPercent)%</span>
                        }
                        else
                        {
                            <span class="position-absolute top-0 start-0 m-3 badge bg-danger rounded-pill fw-bold z-1" style="font-size: 0.75rem;">HOT</span>
                        }
                        
                        <a href="/product/@(string.IsNullOrEmpty(item.Slug) ? HDKmall.Helpers.SlugHelper.GenerateSlug(item.Name) : item.Slug)@(item.VersionId.HasValue ? "?versionId=" + item.VersionId : "")" class="text-center bg-white py-4 d-block" style="height: 220px;">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/img/default.png" : item.ImageUrl)" class="img-fluid" alt="@item.Name" style="max-height: 100%; object-fit: contain;" onerror="this.onerror=null; this.src='/img/default.png';">
                        </a>
                        <div class="card-body d-flex flex-column bg-white">
                            <div class="text-muted small fw-medium mb-1">@(string.IsNullOrEmpty(item.BrandName) ? "Hãng" : item.BrandName)</div>
                            <h5 class="card-title fs-6 lh-sm mb-3">
                                <a href="/product/@(string.IsNullOrEmpty(item.Slug) ? HDKmall.Helpers.SlugHelper.GenerateSlug(item.Name) : item.Slug)@(item.VersionId.HasValue ? "?versionId=" + item.VersionId : "")" class="text-decoration-none text-dark fw-bold">
                                    @item.Name @(string.IsNullOrEmpty(item.VersionName) || item.VersionName.Equals("Mặc định", StringComparison.OrdinalIgnoreCase) || item.Name.Contains(item.VersionName) ? "" : " - " + item.VersionName)
                                </a>
                            </h5>
                            <div class="mt-auto">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <div class="text-danger fw-bolder fs-5">@item.Price.ToString("N0")₫</div>
                                    @if (item.OriginalPrice > item.Price)
                                    {
                                        <div class="text-muted text-decoration-line-through small" style="font-size: 0.8rem;">@item.OriginalPrice.Value.ToString("N0")₫</div>
                                    }
                                </div>
                                <div class="d-flex align-items-center justify-content-between">
                                    <div style="color:#ffc107; font-size:13px;">
                                        @for(int s=1;s<=5;s++){<span>@(s<=(int)Math.Round((double)item.AverageRating)?"\u2605":"\u2606")</span>}
                                        <span class="text-muted" style="font-size:11px;"> @((item.AverageRating).ToString("F1"))</span>
                                    </div>
                                    @{
                                        bool inWishlist = (ViewBag.WishlistProductIds as List<int>)?.Contains(item.Id) ?? false;
                                    }
                                    <button type="button" class="home-wishlist-btn @(inWishlist ? "active" : "")" onclick="toggleHomeWishlist(event,@item.Id,@(item.VersionId??0),this)" title="Yêu thích">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="@(inWishlist ? "#d70018" : "currentColor")" viewBox="0 0 16 16"><path d="M8 2.748l-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01L8 2.748z"/></svg>
                                        <span class="wl-label">@(inWishlist ? "Đã thích" : "Yêu thích")</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

