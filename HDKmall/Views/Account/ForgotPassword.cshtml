@model HDKmall.ViewModels.ForgotPasswordVM
@{
    ViewData["Title"] = "Quên mật khẩu - HDKmall";
}

<div class="container" style="padding-top:40px;padding-bottom:60px;max-width:480px">
    <div class="breadcrumb" style="margin-bottom:24px">
        <a href="/">Trang chủ</a>
        <span class="breadcrumb-sep">›</span>
        <a asp-action="Login">Đăng nhập</a>
        <span class="breadcrumb-sep">›</span>
        <span id="breadcrumb-label">Quên mật khẩu</span>
    </div>

    <div class="auth-form-panel" style="padding: 20px; border: 1px solid #ddd; border-radius: 8px;">
        <h2 class="auth-title text-center mb-3">Khôi phục mật khẩu</h2>
        <p class="auth-subtitle text-center mb-4">Vui lòng nhập email của bạn, chúng tôi sẽ gửi liên kết để đặt lại mật khẩu.</p>

        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3" style="color:red; font-weight: bold;"></div>

            <div class="form-group mb-3">
                <label class="form-label" asp-for="Email">Email <span class="required">*</span></label>
                <input asp-for="Email" class="form-control form-input" placeholder="Nhập email của bạn" style="padding: 10px; width: 100%; border: 1px solid #ccc; border-radius: 4px;" />
                <span asp-validation-for="Email" class="text-danger" style="color:red; display:block; margin-top:5px;"></span>
            </div>
            
            <button type="submit" class="btn btn-primary w-100" style="padding: 12px; background: var(--primary, #007bff); color: white; border: none; border-radius: 4px; cursor: pointer;">Gửi liên kết khôi phục</button>
        </form>

        <div class="text-center mt-4">
            <a asp-action="Login" style="text-decoration: none; color: #666;">&larr; Quay lại Đăng nhập</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
