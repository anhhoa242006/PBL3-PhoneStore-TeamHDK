@{
    ViewData["Title"] = "Đã gửi email - HDKmall";
}

<div class="container text-center" style="padding-top:60px;padding-bottom:100px;max-width:600px">
    <div style="font-size: 60px; color: green; margin-bottom: 20px;">
        ✉️
    </div>
    <h2>Kiểm tra Email của bạn</h2>
    <p class="mt-3" style="font-size: 1.1em; color: #555;">
        Nếu email này đã được đăng ký, chúng tôi vừa gửi cho bạn một liên kết để đặt lại mật khẩu. 
        Vui lòng kiểm tra hộp thư đến (và thư mục Spam/Junk) để nhận liên kết.
    </p>
    <div class="mt-4">
        <a asp-action="Login" class="btn btn-outline-primary" style="padding: 10px 20px; text-decoration: none; border: 1px solid var(--primary, #007bff); border-radius: 4px; color: var(--primary, #007bff);">
            Quay lại Đăng nhập
        </a>
    </div>
</div>
