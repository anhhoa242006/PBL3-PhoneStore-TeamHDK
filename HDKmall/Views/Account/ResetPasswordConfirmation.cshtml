@{
    ViewData["Title"] = "Thành công - HDKmall";
}

<div class="container text-center" style="padding-top:60px;padding-bottom:100px;max-width:600px">
    <div style="font-size: 60px; color: green; margin-bottom: 20px;">
        ✅
    </div>
    <h2>Mật khẩu đã được cập nhật!</h2>
    <p class="mt-3" style="font-size: 1.1em; color: #555;">
        Tài khoản của bạn đã được đặt lại mật khẩu thành công. 
        Bây giờ bạn có thể đăng nhập bằng mật khẩu mới của mình.
    </p>
    <div class="mt-4">
        <a asp-action="Login" class="btn btn-primary" style="padding: 10px 20px; background: var(--primary, #007bff); color: white; border: none; border-radius: 4px; text-decoration: none;">
            Đăng nhập ngay
        </a>
    </div>
</div>
