@model HDKmall.ViewModels.ResetPasswordVM
@{
    ViewData["Title"] = "Đặt lại mật khẩu - HDKmall";
}

<div class="container" style="padding-top:40px;padding-bottom:60px;max-width:480px">
    <div class="auth-form-panel" style="padding: 20px; border: 1px solid #ddd; border-radius: 8px;">
        <h2 class="auth-title text-center mb-3">Tạo mật khẩu mới</h2>
        <p class="auth-subtitle text-center mb-4">Vui lòng nhập mật khẩu mới cho tài khoản của bạn.</p>

        <form asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <div asp-validation-summary="All" class="text-danger mb-3" style="color:red; font-weight: bold;"></div>

            <div class="form-group mb-3">
                <label class="form-label" asp-for="NewPassword">Mật khẩu mới <span class="required">*</span></label>
                <input asp-for="NewPassword" type="password" class="form-control form-input" placeholder="Mật khẩu mới (tối thiểu 6 ký tự)" style="padding: 10px; width: 100%; border: 1px solid #ccc; border-radius: 4px;" />
                <span asp-validation-for="NewPassword" class="text-danger" style="color:red; display:block; margin-top:5px;"></span>
            </div>

            <div class="form-group mb-4">
                <label class="form-label" asp-for="ConfirmPassword">Xác nhận mật khẩu <span class="required">*</span></label>
                <input asp-for="ConfirmPassword" type="password" class="form-control form-input" placeholder="Nhập lại mật khẩu" style="padding: 10px; width: 100%; border: 1px solid #ccc; border-radius: 4px;" />
                <span asp-validation-for="ConfirmPassword" class="text-danger" style="color:red; display:block; margin-top:5px;"></span>
            </div>
            
            <button type="submit" class="btn btn-primary w-100" style="padding: 12px; background: var(--primary, #007bff); color: white; border: none; border-radius: 4px; cursor: pointer;">Lưu mật khẩu mới</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
